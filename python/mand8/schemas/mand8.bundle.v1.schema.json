{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAND8 Bundle",
  "type": "object",
  "required": [
    "schema",
    "bundle_id",
    "case_id",
    "bundle_type",
    "audience",
    "generated_at",
    "institutional_question",
    "receipt",
    "summary",
    "integrity"
  ],
  "properties": {
    "schema": {
      "const": "mand8.bundle.v1"
    },
    "bundle_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "bundle_type": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "institutional_question": {
      "type": "string"
    },
    "market_context": {
      "type": "object"
    },
    "bundle_sections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "receipt": {
      "type": "object",
      "required": [
        "schema",
        "receipt_id",
        "action_id",
        "case_id",
        "issued_at",
        "domain_context",
        "event_trail",
        "human_review",
        "integrity"
      ],
      "properties": {
        "schema": {
          "const": "mand8.risk_receipt.v1"
        },
        "receipt_id": {
          "type": "string"
        },
        "action_id": {
          "type": "string"
        },
        "case_id": {
          "type": "string"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "domain_context": {
          "type": "object"
        },
        "event_trail": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "event_type",
              "payload"
            ],
            "properties": {
              "event_type": {
                "type": "string"
              },
              "payload": {
                "type": "object"
              }
            },
            "additionalProperties": false
          }
        },
        "human_review": {
          "type": "object"
        },
        "integrity": {
          "type": "object",
          "required": [
            "digest",
            "signature_algorithm",
            "signature",
            "core_binding"
          ],
          "properties": {
            "digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "signature_algorithm": {
              "const": "stub-v1"
            },
            "signature": {
              "type": [
                "string",
                "null"
              ]
            },
            "core_binding": {
              "type": [
                "object",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "authority_receipts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "incident_receipts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "related_receipts": {
      "type": "object"
    },
    "coverage_summary": {
      "type": "object"
    },
    "verification_reports": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "string"
    },
    "integrity": {
      "type": "object",
      "required": [
        "digest",
        "signature_algorithm",
        "signature",
        "core_binding"
      ],
      "properties": {
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "signature_algorithm": {
          "const": "stub-v1"
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "core_binding": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
