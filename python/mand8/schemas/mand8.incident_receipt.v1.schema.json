    "incident_id",
    "incident_type",
    "severity",
    "description"
  ],
  "properties": {
    "incident_id": {
      "type": "string"
    },
    "incident_type": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "claims_impact": {
      "type": "string"
    },
    "resolution": {
      "type": "object"
    }
  },
  "additionalProperties": true
