{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["trace_id", "model_family", "model_variant", "groups", "summary_metrics"],
  "properties": {
    "trace_id": {"type": "string"},
    "model_family": {"type": "string"},
    "model_variant": {"type": "string"},
    "basis": {"type": ["string", "null"]},
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "size", "reconstruction_divergence", "bridge_dependence"],
        "properties": {
          "group_id": {"type": "string"},
          "size": {"type": "integer", "minimum": 1},
          "reconstruction_divergence": {"type": "number"},
          "bridge_dependence": {"type": "number"},
          "centroid": {"type": "array", "items": {"type": "number"}},
          "lineage_ids": {"type": "array", "items": {"type": "string"}},
          "topology_metrics": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "summary_metrics": {"type": "object"},
    "artifact_refs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
