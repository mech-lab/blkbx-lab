{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["trace_id", "producer", "created_at", "schema_version", "artifacts"],
  "properties": {
    "trace_id": {"type": "string", "minLength": 1},
    "producer": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "schema_version": {"type": "integer", "const": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_type", "path", "artifact_id", "content_hash", "schema_version"],
        "properties": {
          "artifact_type": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "artifact_id": {"type": "string", "minLength": 1},
          "content_hash": {"type": "string", "minLength": 32},
          "schema_version": {"type": "integer", "const": 1},
          "byte_size": {"type": ["integer", "null"], "minimum": 0}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
