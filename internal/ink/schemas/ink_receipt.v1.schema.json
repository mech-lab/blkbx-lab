{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ink Receipt",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "const": "ink.receipt.v1" },
    "receipt_id": { "type": "string" },
    "issued_at": { "type": "string", "format": "date-time" },
    "issuer": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "key_id": { "type": "string" }
      },
      "required": ["name", "key_id"]
    },
    "model": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "model_id": { "type": "string" },
        "architecture_family": { "type": "string" }
      },
      "required": ["provider", "model_id", "architecture_family"]
    },
    "agent": {
      "type": "object",
      "properties": {
        "agent_id": { "type": "string" },
        "mandate_id": { "type": "string" }
      },
      "required": ["agent_id", "mandate_id"]
    },
    "action": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "customer_impact": { "type": "boolean" },
        "financial_consequence": { "type": "boolean" },
        "binding_effect": { "type": "boolean" }
      },
      "required": ["type", "customer_impact", "financial_consequence", "binding_effect"]
    },
    "gate": {
      "type": "object",
      "properties": {
        "policy": { "type": "string" },
        "decision": { "type": "string", "enum": ["pass", "warn", "escalate", "block"] },
        "reason": { "type": "string" }
      },
      "required": ["policy", "decision", "reason"]
    },
    "evidence": {
      "type": "object",
      "properties": {
        "input_hashes": { "type": "array", "items": { "type": "string" } },
        "policy_refs": { "type": "array", "items": { "type": "string" } },
        "tool_call_hashes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["input_hashes", "policy_refs", "tool_call_hashes"]
    },
    "integrity": {
      "type": "object",
      "properties": {
        "canonicalization": { "type": "string" },
        "hash": { "type": "string" },
        "signature": { "type": "string" }
      },
      "required": ["canonicalization", "hash", "signature"]
    }
  },
  "required": ["schema", "receipt_id", "issued_at", "issuer", "model", "agent", "action", "gate", "evidence", "integrity"]
}
