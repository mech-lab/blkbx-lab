{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Receipt Comparison v2",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "const": "receipt.comparison.v2" },
    "left_receipt_id": { "type": "string" },
    "right_receipt_id": { "type": "string" },
    "comparable": { "type": "boolean" },
    "decision_match": { "type": "boolean" },
    "action_match": { "type": "boolean" },
    "manifest_match": { "type": "boolean" }
  },
  "required": [
    "schema",
    "left_receipt_id",
    "right_receipt_id",
    "comparable",
    "decision_match",
    "action_match",
    "manifest_match"
  ]
