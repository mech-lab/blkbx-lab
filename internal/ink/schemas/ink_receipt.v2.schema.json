{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ink Receipt v2",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "const": "ink.receipt.v2" },
    "receipt_id": { "type": "string" },
    "receipt_profile": { "type": "string", "const": "thin_waist_v2" },
    "action_id": { "type": "string" },
    "issued_at": { "type": "string", "format": "date-time" },
    "issuer": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "key_id": { "type": "string" },
        "algorithm": { "type": "string" },
        "public_key": { "type": "string" }
      },
      "required": ["name", "key_id", "algorithm", "public_key"]
    },
    "manifest": {
      "type": "object",
      "properties": {
        "manifest_hash": { "type": "string" }
      },
      "required": ["manifest_hash"]
    },
    "policy": {
      "type": "object",
      "properties": {
        "policy_id": { "type": "string" },
        "policy_version": { "type": "string" },
        "policy_hash": { "type": "string" }
      },
      "required": ["policy_id", "policy_version", "policy_hash"]
    },
    "model": { "type": "object" },
    "facts": { "type": "object" },
    "decision": {
      "type": "object",
      "properties": {
        "decision": { "type": "string", "enum": ["pass", "warn", "escalate", "block"] },
        "reasons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["decision", "reasons"]
    },
    "evidence": {
      "type": "object",
      "properties": {
        "manifest_hash": { "type": "string" },
        "evidence_summary_hash": { "type": "string" },
        "controls_summary_hash": { "type": "string" }
      },
      "required": ["manifest_hash", "evidence_summary_hash", "controls_summary_hash"]
    },
    "controls": {
      "type": "object",
      "properties": {
        "observations": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["observations"]
    },
    "signing": {
      "type": "object",
      "properties": {
        "canonicalization": { "type": "string" },
        "payload_hash": { "type": "string" },
        "algorithm": { "type": "string" },
        "key_id": { "type": "string" },
        "public_key": { "type": "string" },
        "signature": { "type": "string" }
      },
      "required": ["canonicalization", "payload_hash", "algorithm", "key_id", "public_key", "signature"]
    }
  },
  "required": [
    "schema",
    "receipt_id",
    "receipt_profile",
    "action_id",
    "issued_at",
    "issuer",
    "manifest",
    "policy",
    "model",
    "facts",
    "decision",
    "evidence",
    "controls",
    "signing"
  ]
}
