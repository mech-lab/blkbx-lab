{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ink Manifest",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "const": "ink.manifest.v1" },
    "action_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifact_type": { "type": "string" },
          "content_hash": { "type": "string" },
          "path": { "type": "string" }
        },
        "required": ["artifact_type", "content_hash", "path"]
      }
    }
  },
  "required": ["schema", "action_id", "artifacts"]
}
