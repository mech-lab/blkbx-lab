{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ink Manifest v2",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "const": "ink.manifest.v2" },
    "action_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "artifact_type": { "type": "string" },
          "media_type": { "type": "string" },
          "path": { "type": "string" },
          "path_hash": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "content_hash": { "type": "string" },
          "schema_hash": { "type": ["string", "null"] },
          "path_hint": { "type": "string" }
        },
        "required": [
          "artifact_type",
          "media_type",
          "path",
          "path_hash",
          "size_bytes",
          "content_hash",
          "schema_hash",
          "path_hint"
        ]
      }
    }
  },
  "required": ["schema", "action_id", "created_at", "artifacts"]
}
