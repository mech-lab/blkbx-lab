{
  "schema": "ink.policy.v1",
  "id": "human-review-required",
  "version": "0.6",
  "default": {
    "decision": "block",
    "reason": "human_review_required"
  },
  "rules": [
    {
      "id": "approved-human-review",
      "priority": 100,
      "when": { "control": "HumanReview", "status": "approved" },
      "effect": {
        "decision": "pass",
        "reason": "human_review_present"
      }
    }
  ]
}
