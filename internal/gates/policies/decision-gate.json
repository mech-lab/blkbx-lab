{
  "schema": "ink.policy.v1",
  "id": "decision-gate",
  "version": "0.6",
  "default": {
    "decision": "pass",
    "reason": "non_binding"
  },
  "rules": [
    {
      "id": "binding-effect-escalation",
      "priority": 100,
      "when": { "fact": "binding_effect_present", "equals": true },
      "effect": {
        "decision": "escalate",
        "reason": "binding_effect_requires_escalation"
      }
    }
  ]
}
