{
  "schema": "ink.policy.v1",
  "id": "action-gate",
  "version": "0.6",
  "default": {
    "decision": "pass",
    "reason": "low_risk"
  },
  "rules": [
    {
      "id": "human-review-required",
      "priority": 100,
      "when": {
        "and": [
          { "fact": "requires_human_review", "equals": true },
          { "not": { "control": "HumanReview", "status": "approved" } }
        ]
      },
      "effect": {
        "decision": "block",
        "reason": "human_review_required"
      }
    },
    {
      "id": "medium-risk-warning",
      "priority": 50,
      "when": { "fact": "risk_class", "equals": "medium" },
      "effect": {
        "decision": "warn",
        "reason": "elevated_risk"
      }
    }
  ]
}
