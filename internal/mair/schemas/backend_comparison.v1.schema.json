{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "left_trace_id",
    "right_trace_id",
    "backend_pair",
    "schema_match",
    "bridge_dependence_delta",
    "tract_retention_delta"
  ],
  "properties": {
    "left_trace_id": {"type": "string"},
    "right_trace_id": {"type": "string"},
    "backend_pair": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "string"}
    },
    "schema_match": {"type": "boolean"},
    "bridge_dependence_delta": {"type": "number"},
    "tract_retention_delta": {"type": "number"},
    "topology_distance": {"type": ["number", "null"]},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
