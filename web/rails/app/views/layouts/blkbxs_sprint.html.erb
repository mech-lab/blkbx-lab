<!DOCTYPE html>
<html>
  <head>
    <title>BLKBXS Sprint Console</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      :root {
        color-scheme: light;
        --ink: #16201b;
        --muted: #5d6b63;
        --line: #d9e1dc;
        --panel: #ffffff;
        --surface: #f6f8f5;
        --accent: #0f6b4b;
        --accent-soft: #e2f2ea;
        --warn: #a56300;
        --danger: #9f2b2b;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--ink);
        background: var(--surface);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        letter-spacing: 0;
      }
      a { color: inherit; text-decoration: none; }
      .shell { min-height: 100vh; display: grid; grid-template-columns: 260px 1fr; }
      .side {
        background: #ffffff;
        border-right: 1px solid var(--line);
        padding: 22px 18px;
      }
      .brand { font-size: 15px; font-weight: 750; margin-bottom: 4px; }
      .offer { color: var(--muted); font-size: 12px; line-height: 1.4; margin-bottom: 22px; }
      .nav { display: grid; gap: 6px; }
      .nav a {
        display: block;
        border: 1px solid transparent;
        border-radius: 6px;
        padding: 9px 10px;
        color: #2a352f;
        font-size: 13px;
      }
      .nav a:hover { background: var(--accent-soft); border-color: #bedccc; }
      .main { padding: 24px; min-width: 0; }
      .page-head { display: flex; justify-content: space-between; gap: 20px; align-items: flex-start; margin-bottom: 20px; }
      h1 { margin: 0; font-size: 26px; line-height: 1.15; letter-spacing: 0; }
      h2 { margin: 0 0 12px; font-size: 16px; letter-spacing: 0; }
      .subtle { color: var(--muted); font-size: 13px; line-height: 1.45; }
      .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 14px;
      }
      .metric { font-size: 24px; font-weight: 760; margin-top: 6px; }
      .label { color: var(--muted); font-size: 12px; text-transform: uppercase; }
      .stack { display: grid; gap: 14px; }
      .split { display: grid; grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr); gap: 14px; }
      table { width: 100%; border-collapse: collapse; background: var(--panel); border: 1px solid var(--line); border-radius: 8px; overflow: hidden; }
      th, td { padding: 10px 12px; border-bottom: 1px solid var(--line); text-align: left; vertical-align: top; font-size: 13px; }
      th { background: #eef3ef; color: #34443b; font-weight: 700; }
      tr:last-child td { border-bottom: 0; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 12px; overflow-wrap: anywhere; }
      .badge { display: inline-flex; align-items: center; min-height: 24px; padding: 3px 8px; border-radius: 999px; background: #edf1ee; font-size: 12px; color: #2d3932; }
      .badge.ok { background: var(--accent-soft); color: var(--accent); }
      .badge.warn { background: #fff3dc; color: var(--warn); }
      .badge.danger { background: #fbe5e5; color: var(--danger); }
      @media (max-width: 900px) {
        .shell { grid-template-columns: 1fr; }
        .side { border-right: 0; border-bottom: 1px solid var(--line); }
        .grid, .split { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <% current_case = @loan_case || @active_case %>
    <div class="shell">
      <aside class="side">
        <div class="brand">BLKBXS Sprint Console</div>
        <div class="offer">SMB $250,000 conditional approval evidence sprint</div>
        <nav class="nav">
          <%= link_to "Sprint dashboard", blkbxs_sprint_root_path %>
          <% if current_case %>
            <%= link_to "Loan case", blkbxs_sprint_loan_case_path(current_case) %>
            <%= link_to "Evidence timeline", timeline_blkbxs_sprint_loan_case_path(current_case) %>
            <%= link_to "Receipt graph", receipt_graph_blkbxs_sprint_loan_case_path(current_case) %>
            <%= link_to "Verification console", verification_blkbxs_sprint_loan_case_path(current_case) %>
            <%= link_to "Reviewer objections", objections_blkbxs_sprint_loan_case_path(current_case) %>
            <%= link_to "Export room", exports_blkbxs_sprint_loan_case_path(current_case) %>
          <% end %>
        </nav>
      </aside>
      <main class="main">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
