{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "op",
    "trace_id",
    "model_family",
    "model_variant",
    "block_id",
    "token_span",
    "source_artifact_id",
    "determinism_context",
    "payload"
  ],
  "properties": {
    "op": {"type": "string", "enum": ["StateInit", "StateRead", "StateUpdate", "TransportApply", "GateApply", "BridgeApply", "Intervention", "Topology", "Receipt"]},
    "trace_id": {"type": "string"},
    "model_family": {"type": "string"},
    "model_variant": {"type": "string"},
    "block_id": {"type": "string"},
    "token_span": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "integer", "minimum": 0}
    },
    "source_artifact_id": {"type": "string"},
    "determinism_context": {"type": "object"},
    "payload": {"type": "object"}
  },
  "additionalProperties": false
}
