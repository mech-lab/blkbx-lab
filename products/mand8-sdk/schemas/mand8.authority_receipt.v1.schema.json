{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MAND8 Authority Receipt",
  "type": "object",
  "required": [
    "schema",
    "receipt_id",
    "action_id",
    "case_id",
    "issued_at",
    "domain_context",
    "authority_scope",
    "event_trail",
    "human_review",
    "integrity"
  ],
  "properties": {
    "schema": {
      "const": "mand8.authority_receipt.v1"
    },
    "receipt_id": {
      "type": "string"
    },
    "action_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "domain_context": {
      "type": "object",
      "required": [
        "case_id",
        "policy_ref",
        "binder_ref"
      ],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "policy_ref": {
          "type": "string"
        },
        "binder_ref": {
          "type": "string"
        },
        "lloyds_binding_ref": {
          "type": "string"
        },
        "territory": {
          "type": "string"
        },
        "market_segment": {
          "type": "string"
        },
        "managing_agent": {
          "type": [
            "string",
            "null"
          ]
        },
        "coverholder": {
          "type": [
            "string",
            "null"
          ]
        },
        "regulators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "authority_scope": {
      "type": "object",
      "required": [
        "authority_id",
        "construct",
        "status"
      ],
      "properties": {
        "authority_id": {
          "type": "string"
        },
        "construct": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "delegated_authority": {
          "type": "boolean"
        },
        "permitted_risk_classes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "controls_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclusions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authority_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "event_trail": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "event_type",
          "payload"
        ],
        "properties": {
          "event_type": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "human_review": {
      "type": "object",
      "required": [
        "reviewer",
        "notes",
        "status",
        "reviewed_at"
      ],
      "properties": {
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string"
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "integrity": {
      "type": "object",
      "required": [
        "digest",
        "signature_algorithm",
        "signature",
        "core_binding"
      ],
      "properties": {
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "signature_algorithm": {
          "const": "stub-v1"
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "core_binding": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
